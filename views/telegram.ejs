<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Telegram Login - Auth Service</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
</head>
<body>
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">🔐 Auth Service</a>
        <div class="nav-menu">
          <a href="/" class="nav-link">Назад</a>
        </div>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <div class="auth-container">
        <div class="auth-card">
          <h1 class="auth-title">✈️ Telegram Login</h1>
          
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          
          <div class="telegram-info">
            <p>Для входа через Telegram:</p>
            <ol>
              <li>Откройте бота <strong><%= botUsername %></strong></li>
              <li>Отправьте команду <code>/start</code></li>
              <li>Нажмите кнопку "Войти" в боте</li>
            </ol>
          </div>
          
          <div id="telegram-login-status">
            <p>Ожидание авторизации...</p>
            <div class="loading-spinner"></div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>Auth Service &copy; <%= new Date().getFullYear() %></p>
    </div>
  </footer>

  <script>
    // Debug: Log when script starts
    console.log('Telegram auth page loaded');
    
    // Check if we're running in Telegram WebApp
    if (window.Telegram && window.Telegram.WebApp) {
      const tg = window.Telegram.WebApp;
      
      console.log('Telegram WebApp detected');
      console.log('initData available:', !!tg.initData);
      console.log('initData length:', tg.initData ? tg.initData.length : 0);
      
      // Function to perform authentication
      function performAuth() {
        const initData = tg.initData;
        
        console.log('performAuth called, initData:', initData ? 'present' : 'missing');
        
        if (!initData) {
          document.getElementById('telegram-login-status').innerHTML = 
            '<p class="alert alert-error">❌ Не удалось получить данные Telegram (initData пуст)</p>';
          return;
        }
        
        document.getElementById('telegram-login-status').innerHTML = 
          '<p>Выполняется авторизация...</p><div class="loading-spinner"></div>';
        
        // Send initData to backend for authentication
        fetch('/auth/telegram', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: 'initData=' + encodeURIComponent(initData)
        })
        .then(response => {
          console.log('Response status:', response.status);
          return response.json();
        })
        .then(data => {
          console.log('Auth response:', data);
          if (data.success) {
            document.getElementById('telegram-login-status').innerHTML = 
              '<p class="alert alert-success">✅ Успешная авторизация!</p>';
            
            // Send success message back to bot
            tg.sendData(JSON.stringify({ success: true, redirect: data.redirect }));
            
            // Close web app after short delay
            setTimeout(() => {
              tg.close();
            }, 1500);
          } else {
            document.getElementById('telegram-login-status').innerHTML = 
              '<p class="alert alert-error">❌ Ошибка: ' + (data.error || 'Неизвестная ошибка') + '</p>';
            
            tg.sendData(JSON.stringify({ success: false, error: data.error }));
          }
        })
        .catch(error => {
          console.error('Auth error:', error);
          document.getElementById('telegram-login-status').innerHTML = 
            '<p class="alert alert-error">❌ Ошибка соединения: ' + error.message + '</p>';
        });
      }
      
      // Initialize - expand and wait for ready
      tg.expand();
      console.log('WebApp expanded');
      
      // Use ready() to ensure SDK is fully initialized
      tg.ready(() => {
        console.log('Telegram WebApp ready callback');
        checkAndAuth();
      });
      
      // Also check immediately in case already ready
      if (tg.initData) {
        console.log('initData already available immediately');
        checkAndAuth();
      }
      
      function checkAndAuth() {
        console.log('checkAndAuth called, initData:', tg.initData ? 'present' : 'missing');
        if (tg.initData) {
          performAuth();
        } else {
          // Wait and retry
          setTimeout(() => {
            if (tg.initData) {
              performAuth();
            } else {
              document.getElementById('telegram-login-status').innerHTML = 
                '<p class="alert alert-error">❌ Не удалось получить данные Telegram</p>';
            }
          }, 500);
        }
      }
      
    } else {
      // Not running in Telegram - show helpful message
      console.log('Not running in Telegram WebApp');
      document.getElementById('telegram-login-status').innerHTML = 
        '<p class="alert alert-error">⚠️ Авторизация через Telegram работает только внутри бота</p>';
    }
  </script>
</body>
</html>

