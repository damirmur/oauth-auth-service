<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ошибка - Auth Service</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="logo">🔐 Auth Service</a>
        <div class="nav-menu">
          <a href="/" class="nav-link">Главная</a>
          <a href="/login" class="nav-link">Вход</a>
        </div>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <div class="error-page">
        <h1>❌ Ошибка</h1>
        <div class="alert alert-error">
          <%= error %>
        </div>
        <a href="/" class="btn btn-primary">На главную</a>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>Auth Service &copy; <%= new Date().getFullYear() %></p>
    </div>
  </footer>
</body>
</html>

